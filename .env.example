# BTC SNIPER BOT — Environment Variables
# Copy this file to .env and fill in your values

# ── Exchange Data Source ──────────────────────────────
# auto = tries bybit → okx → binance → bingx in order
DATA_SOURCE=auto

# ── Trading Pair & Timeframe ──────────────────────────
SYMBOL=BTC-USDT
INTERVAL=15m
POLL_INTERVAL_MS=30000

# ── BingX API (for positions & account data) ─────────
BINGX_API_KEY=your_bingx_api_key_here
BINGX_API_SECRET=your_bingx_api_secret_here
BINGX_BASE=https://open-api.bingx.com

# ── Other Exchange Bases (fallback) ───────────────────
BINANCE_BASE=https://fapi.binance.com
BYBIT_BASE=https://api.bybit.com
OKX_BASE=https://www.okx.com

# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Server ────────────────────────────────────────────
PORT=3001
